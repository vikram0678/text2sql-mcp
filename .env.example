# Your Anthropic Claude API key.
# Leave EMPTY to use Ollama (local) instead — which is your setup!
ANTHROPIC_API_KEY=

# Path to the SQLite database inside the container. Do not change this.
DATABASE_URL=sqlite:///./data/sales.db

# Ollama settings — these match your installed setup
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2